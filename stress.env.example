STRESS_BASE_URL=http://127.0.0.1:8080
STRESS_API_KEY=replace-with-your-rest-api-key
STRESS_FIXTURE_PATH=testdata/stress/fixtures.json
STRESS_TIMEOUT=30s
STRESS_WARMUP=3s
STRESS_MAX_IDLE_CONNS=128
STRESS_MAX_IDLE_CONNS_PER_HOST=64
STRESS_MAX_CONNS_PER_HOST=0
STRESS_IDLE_CONN_TIMEOUT=90s

# Scenario selection
STRESS_SCENARIO=smoke

# Global thresholds
STRESS_THRESHOLD_P95_MS=2200
STRESS_THRESHOLD_P99_MS=3000
STRESS_THRESHOLD_MIN_RPS=2.0
STRESS_THRESHOLD_MAX_ERROR_RATE=0.02

# Mix and conversation behavior
STRESS_HOT_CONVERSATIONS=8
STRESS_UPLOAD_EVERY=5
STRESS_HEALTH_EVERY=10
STRESS_LIST_EVERY=7
STRESS_LIST_LIMIT=25

# Scenario tuning
STRESS_SMOKE_DURATION=15s
STRESS_SMOKE_CONCURRENCY=1
STRESS_SUSTAINED_DURATION=2m
STRESS_SUSTAINED_CONCURRENCY=6
STRESS_SPIKE_DURATION=75s
STRESS_SPIKE_CONCURRENCY=12
STRESS_BREAKPOINT_START=2
STRESS_BREAKPOINT_MAX=24
STRESS_BREAKPOINT_STEP=2
STRESS_BREAKPOINT_STAGE_DURATION=20s
